#!/usr/bin/env sh
# Commit message convention validation
# Format : <type>(scope?): 내용
# Type   : feat | fix | docs | style | refactor | setting | chore

commit_msg=$(cat "$1")

# 머지 커밋은 검증 제외
case "$commit_msg" in Merge*) exit 0 ;; esac

pattern='^(feat|fix|docs|style|refactor|setting|chore)(\([a-z0-9-]+\))?: .+'

if ! echo "$commit_msg" | grep -Eq "$pattern"; then
  echo ""
  echo "커밋 메시지 컨벤션 위반."
  echo ""
  echo "받은 메시지: \"$commit_msg\""
  echo ""
  echo "형식: <type>(scope): 내용"
  echo "  type: feat | fix | docs | style | refactor | setting | chore"
  echo "  scope: 소문자, 숫자, 하이픈"
  echo ""
  echo "예시:"
  echo "  feat(admin): 어드민 로그인 로직 구현"
  echo "  fix(auth): 토큰 만료 시 재발급 실패 버그 수정"
  echo ""
  exit 1
fi
